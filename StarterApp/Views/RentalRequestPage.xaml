<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.RentalRequestPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             x:DataType="viewmodels:RentalRequestViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Label Text="Requesting to Rent:" FontAttributes="Bold" FontSize="16" />
            <Label Text="{Binding ItemTitle}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <Label Text="Start Date" FontAttributes="Bold" />
            <DatePicker Date="{Binding StartDate}" />

            <Label Text="End Date" FontAttributes="Bold" />
            <DatePicker Date="{Binding EndDate}" />

            <Label Text="Optional Message to Owner" FontAttributes="Bold" />
            <Editor Text="{Binding Message}" AutoSize="TextChanges" HeightRequest="100" />

            <Button Text="Submit Request" Command="{Binding SubmitRequestCommand}" Margin="0,16,0,0" />
            <Button Text="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButtonStyle}" />

            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#2A1414}"
                    Stroke="{AppThemeBinding Light=#EF5350, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="12"
                    Margin="0,16,0,0">
                <Label Text="{Binding ErrorMessage}" TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
