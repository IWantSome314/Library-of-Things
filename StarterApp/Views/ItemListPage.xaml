<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             xmlns:models="clr-namespace:StarterApp.Models"
             x:DataType="viewmodels:ItemListViewModel"
             Title="Items">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Home"
                     Command="{Binding NavigateToDashboardCommand}" />
        <ToolbarItem Text="Add"
                     Command="{Binding CreateItemCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="12">
        <HorizontalStackLayout Grid.Row="0"
                               Spacing="10"
                               Margin="0,0,0,10">
            <Button Text="Browse Listings"
                    Command="{Binding ShowBrowseListingsCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding ShowingBrowseListings}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding ShowingBrowseListings}" Value="False">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Text="My Listings"
                    Command="{Binding ShowMyListingsCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding ShowingMyListings}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding ShowingMyListings}" Value="False">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </HorizontalStackLayout>

        <SearchBar Grid.Row="1"
                   Text="{Binding SearchText}"
                   Placeholder="Search by title, category or location" />

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No items found"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ItemListRow">
                        <Border Margin="0,6"
                                Padding="12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemListViewModel}}, Path=OpenItemCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontSize="17"
                                       FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DailyRate, StringFormat='£{0:F2}/day'}"
                                       FontSize="14" />
                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding Category}"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding Location}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="{Binding OwnerName}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />

                                <HorizontalStackLayout Grid.Row="3"
                                               Grid.ColumnSpan="2"
                                               Spacing="10"
                                               Margin="0,10,0,0">
                                    <Button Text="View"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemListViewModel}}, Path=OpenItemCommand}"
                                        CommandParameter="{Binding .}" />
                                    <Button Text="Request"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemListViewModel}}, Path=RequestItemCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource OutlineButtonStyle}"
                                        IsVisible="{Binding CanRequest}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Border IsVisible="{Binding HasError}"
                BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#2A1414}"
                Stroke="{AppThemeBinding Light=#EF5350, Dark=#EF5350}"
                Padding="10"
                VerticalOptions="End">
            <Label Text="{Binding ErrorMessage}" />
        </Border>
    </Grid>
</ContentPage>
